{
  "name": "holo-interface",
  "private": true,
  "version": "0.1.0",
  "engines": { "node": ">=20", "pnpm": ">=8" },
  "packageManager": "pnpm@8.15.0",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
